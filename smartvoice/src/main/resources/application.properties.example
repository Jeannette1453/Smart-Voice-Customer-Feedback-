# ── Copy this file to application.properties and fill in your values ──

spring.application.name=smartvoice
server.port=8080

# Database
spring.datasource.url=jdbc:postgresql://localhost:5432/smartvoice_db
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false

# JWT
jwt.secret=YOUR_JWT_SECRET_KEY_HERE
jwt.expiration=86400000

# Frontend URL
app.frontend.url=http://localhost:5173
app.cors.allowed-origins=http://localhost:5173

# Google OAuth
google.client-id=YOUR_GOOGLE_CLIENT_ID_HERE

# Email (Gmail SMTP)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=YOUR_EMAIL@gmail.com
spring.mail.password=YOUR_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# AI Service
ai.base-url=http://localhost:8001
ai.service.base-url=http://localhost:8001
app.ai.enabled=false
app.ai.base-url=http://localhost:8000

# File Upload
smartvoice.upload.dir=uploads
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
